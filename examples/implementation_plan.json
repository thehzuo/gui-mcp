{
  "v": "0.1",
  "artifact": "implementation_plan",
  "title": "Web GUI MCP MVP",
  "subtitle": "Static-first renderer with optional MCP App delivery",
  "audience": "team",
  "density": "compact",
  "theme": "technical",
  "sections": [
    {
      "kind": "summary",
      "items": [
        { "label": "Scope", "value": "5 artifact patterns", "tone": "info" },
        { "label": "Storage", "value": "In-memory", "tone": "neutral" },
        { "label": "Default output", "value": "Static HTML", "tone": "good" }
      ]
    },
    {
      "kind": "narrative",
      "title": "Thesis",
      "body": "The model emits semantic artifact specs, while the MCP server compiles those specs into rich HTML. This minimizes token cost and keeps rendering safe and consistent."
    },
    {
      "kind": "flow",
      "title": "Request Flow",
      "nodes": [
        { "id": "agent", "label": "Agent", "description": "Submits compact ArtifactSpec JSON." },
        { "id": "server", "label": "MCP server", "description": "Validates and renders deterministic HTML." },
        { "id": "host", "label": "Host", "description": "Displays HTML or fetches a ui resource." }
      ],
      "edges": [
        { "from": "agent", "to": "server", "label": "tool call" },
        { "from": "server", "to": "host", "label": "HTML or ui URI" }
      ]
    },
    {
      "kind": "timeline",
      "title": "Implementation Phases",
      "events": [
        { "label": "Scaffold package", "status": "done" },
        { "label": "Add ArtifactSpec schema", "status": "done" },
        { "label": "Implement renderer", "status": "active" },
        { "label": "Add tests and docs", "status": "planned" }
      ]
    },
    {
      "kind": "matrix",
      "title": "Risks",
      "x_axis": "Risk",
      "y_axis": "Mitigation",
      "cells": [
        { "x": "Unsafe text", "y": "Escape centrally", "label": "All model text passes through html.escape.", "tone": "good" },
        { "x": "Large HTML", "y": "Resource delivery", "label": "Return ui resource URI by default.", "tone": "info" },
        { "x": "Host support", "y": "Static fallback", "label": "Full HTML remains usable outside MCP Apps.", "tone": "warning" }
      ]
    },
    {
      "kind": "checklist",
      "title": "Done Criteria",
      "items": [
        { "text": "uv sync or pip install -e . works", "priority": "high" },
        { "text": "pytest passes", "priority": "high" },
        { "text": "All examples render to HTML", "priority": "high" },
        { "text": "No arbitrary model JavaScript is rendered", "priority": "high" }
      ]
    },
    {
      "kind": "source_list",
